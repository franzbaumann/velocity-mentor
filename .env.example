# Frontend env vars (Vite inlines only VITE_* — never put secrets here)
# Copy to .env and fill in. .env is gitignored.

VITE_SUPABASE_PROJECT_ID=your_project_ref
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Local scripts (backfillSessions, backfillActivityMatching) auto-load this file from repo root.
# Never commit real secrets. Never prefix with VITE_ (would expose to the browser build).
# SUPABASE_SERVICE_ROLE_KEY=paste_from_dashboard_settings_api

# Strava OAuth - get from https://www.strava.com/settings/api
# Client secret goes in Supabase Edge Function secrets, NOT here
VITE_STRAVA_CLIENT_ID=your_strava_client_id

# Optional
VITE_NEW_ONBOARDING=false
